# SQLite cho dev local
DATABASE_URL="file:./dev.db"

# Khi deploy Vercel, đổi sang Postgres (Neon, Supabase, Vercel Postgres):
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Secret cho JWT session (tạo chuỗi ngẫu nhiên dài)
AUTH_SECRET="change-me-super-secret-min-32-chars-please"

# (Tuỳ chọn) SMTP để gửi email thông báo khoa
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="healthcheck@lienchieu.vn"
