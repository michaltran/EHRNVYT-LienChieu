generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  CONCLUDER
  DEPT_REP
  EMPLOYEE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ExamRoundStatus {
  DRAFT
  OPEN
  CLOSED
}

enum RecordStatus {
  PENDING
  IN_PROGRESS
  WAITING_REVIEW
  WAITING_CONCLUSION
  COMPLETED
}

enum HealthClassification {
  LOAI_I
  LOAI_II
  LOAI_III
  LOAI_IV
  LOAI_V
}

enum Specialty {
  NOI_TUAN_HOAN
  NOI_HO_HAP
  NOI_TIEU_HOA
  NOI_THAN_TIET_NIEU
  NOI_TIET
  CO_XUONG_KHOP
  THAN_KINH
  TAM_THAN
  NGOAI_KHOA
  DA_LIEU
  SAN_PHU_KHOA
  MAT
  TAI_MUI_HONG
  RANG_HAM_MAT
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  fullName         String
  role             Role      @default(EMPLOYEE)
  specialties      String?
  signatureDataUrl String?
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id])
  employeeId       String?   @unique
  employee         Employee? @relation(fields: [employeeId], references: [id])
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  examsAsDoctor     ExamClinical[] @relation("DoctorExam")
  conclusionsSigned HealthRecord[] @relation("Concluder")
  auditLogs         AuditLog[]
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?  @unique
  createdAt DateTime @default(now())

  employees Employee[]
  users     User[]
}

model Employee {
  id               String     @id @default(cuid())
  employeeCode     String?    @unique
  fullName         String
  gender           Gender
  dateOfBirth      DateTime?
  idNumber         String?
  idIssuedDate     DateTime?
  idIssuedPlace    String?
  phone            String?
  currentAddress   String?
  occupation       String?
  workplace        String?
  startWorkingDate DateTime?
  position         String?
  employmentType   String?
  qualification    String?
  jobTitle         String?
  photoUrl         String?
  familyHistory    String?
  personalHistory  String?
  previousJobs     String?
  departmentId     String
  department       Department @relation(fields: [departmentId], references: [id])
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  healthRecords HealthRecord[]
  user          User?
}

model ExamRound {
  id        String          @id @default(cuid())
  name      String
  year      Int
  startDate DateTime
  endDate   DateTime?
  status    ExamRoundStatus @default(DRAFT)
  createdAt DateTime        @default(now())

  healthRecords HealthRecord[]
}

model HealthRecord {
  id                        String       @id @default(cuid())
  employeeId                String
  employee                  Employee     @relation(fields: [employeeId], references: [id])
  examRoundId               String
  examRound                 ExamRound    @relation(fields: [examRoundId], references: [id])
  status                    RecordStatus @default(PENDING)
  height                    Float?
  weight                    Float?
  bmi                       Float?
  pulse                     Int?
  bloodPressureSys          Int?
  bloodPressureDia          Int?
  physicalClassification    String?
  finalClassification       HealthClassification?
  conclusionText            String?
  concluderId               String?
  concluder                 User?        @relation("Concluder", fields: [concluderId], references: [id])
  concluderSignedAt         DateTime?
  concluderSignatureDataUrl String?
  medicalHistoryNote        String?
  obstetricHistory          String?
  adminReviewNote           String?
  reviewedAt                DateTime?
  finalizedAt               DateTime?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  clinicalExams ExamClinical[]
  paraclinicals Paraclinical[]

  @@unique([employeeId, examRoundId])
}

model ExamClinical {
  id               String       @id @default(cuid())
  recordId         String
  record           HealthRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  specialty        Specialty
  findings         String?
  classification   String?
  extraData        String?
  doctorId         String?
  doctor           User?        @relation("DoctorExam", fields: [doctorId], references: [id])
  signedAt         DateTime?
  signatureDataUrl String?
  updatedAt        DateTime     @updatedAt

  @@unique([recordId, specialty])
}

model Paraclinical {
  id         String       @id @default(cuid())
  recordId   String
  record     HealthRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  category   String
  testName   String
  result     String?
  note       String?
  evaluation String?
  fileUrl    String?
  createdAt  DateTime     @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  target    String?
  detail    String?
  createdAt DateTime @default(now())
}